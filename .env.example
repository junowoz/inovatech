# Supabase — public project URL and publishable key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback, only if your project still uses anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL for media served from the Supabase "midia" storage bucket.
# Format: <SUPABASE_URL>/storage/v1/object/public/midia/
NEXT_PUBLIC_MIDIA_URL=https://your-project-ref.supabase.co/storage/v1/object/public/midia/

# Canonical site URL (used for SEO metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://inovatech.junowoz.com

# Public base URL for downloadable files (Manual page). Trailing slash required.
NEXT_PUBLIC_FILES_URL=https://your-project-ref.supabase.co/storage/v1/object/public/files/

# Google Analytics measurement id (optional — analytics disabled if unset)
NEXT_PUBLIC_GA_ID=

# Public contact links shown in footer and signup pages.
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_WHATSAPP_URL=
NEXT_PUBLIC_CONTACT_ADDRESS_URL=
